# Supabase credentials — copy this file to .env and fill in your project values.
# Found in the Supabase dashboard under Project Settings → API.
# Leave blank to run the app fully offline (auth & cloud sync are disabled when unset).
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
